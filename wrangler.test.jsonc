{
  "name": "arxiv-report",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "d1_databases": [{ "binding": "DB", "database_name": "arxiv-report", "database_id": "test-db-id" }],
  "kv_namespaces": [{ "binding": "CACHE", "id": "test-kv-id" }],
  "vars": {
    "MIN_SCORE": "0.62",
    "DAILY_GEN_CAP": "50",
